# ───────────────────────────────────────────────────────────────────────────
# KOSATKA Mesh — AGENT node example environment.
#
# Copy to `.env.agent` on each agent host and edit before running:
#
#     docker compose -f docker-compose.agent.yml up -d --build
#
# OR, for non-Docker development:
#
#     cp .env.agent.example .env
#     kosatka-mesh agent run --port 8010
#
# Every variable is read by `kosatka_agent/config.py` and prefixed with
# `AGENT_` at runtime, except for the master-coordination block at the
# bottom (used only by the install / registration scripts, not by the
# agent process itself).
# ───────────────────────────────────────────────────────────────────────────

# Shared secret the master uses when calling this agent. Pick a random
# string per agent and tell the master about it via:
#     kosatka-mesh nodes add --name "..." --url "..." --key "<this value>"
AGENT_API_KEY=change-me-per-agent

# Which VPN backend the agent should expose: wireguard | awg | marzban | xray.
AGENT_PROVIDER_TYPE=wireguard

# Marzban-specific overrides (only when AGENT_PROVIDER_TYPE=marzban).
# AGENT_MARZBAN_URL=https://marzban.example.com
# AGENT_MARZBAN_USERNAME=admin
# AGENT_MARZBAN_PASSWORD=change-me

# AmneziaWG / WireGuard config locations. The defaults baked into
# `kosatka_agent/config.py` work for the ansible-managed installs in
# this repo; override only if you know your tunnel lives elsewhere.
# AGENT_AWG_CONFIG_PATH=/etc/amnezia/amneziawg/wg0.conf
# AGENT_AWG_INTERFACE=wg0
# AGENT_WG_CONFIG_PATH=/etc/wireguard/wg0.conf
# AGENT_WG_INTERFACE=wg0

# ───────────────────────────────────────────────────────────────────────────
# Master coordination — used by remote-install / nodes-add scripts only.
# ───────────────────────────────────────────────────────────────────────────

# Public URL of the master API.
KOSATKA_MASTER_URL=https://your-master-domain.example.com

# Master's KOSATKA_API_KEY, used by registration scripts to call the
# master's `/api/v1/nodes/...` endpoints from the agent host. Leave blank
# if you register nodes manually from a separate CLI host.
KOSATKA_API_KEY=
