# ───────────────────────────────────────────────────────────────────────────
# KOSATKA Mesh — MASTER node example environment.
#
# Copy to `.env.master` and edit before running:
#
#     docker compose -f docker-compose.master.yml --env-file .env.master \
#         up -d --build
#
# OR, for non-Docker development:
#
#     cp .env.master.example .env
#     kosatka-mesh master run --port 8000
#
# Every variable is read by `kosatka_master/config.py` and prefixed with
# `KOSATKA_` at runtime. See `.env.agent.example` for the agent surface.
# ───────────────────────────────────────────────────────────────────────────

# Admin API key. Required by every `/api/v1/*` endpoint (header
# `X-Kosatka-Key`). Pick a long random string — anyone with this can
# provision and revoke VPN profiles.
KOSATKA_API_KEY=change-me-to-a-long-random-string

# Optional: separate key the master uses when CALLING agents. Defaults
# to KOSATKA_API_KEY for single-host dev. In production, set this to the
# AGENT_API_KEY of the registered nodes.
# KOSATKA_AGENT_API_KEY=

# SQLAlchemy async URL. The master container in docker-compose.master.yml
# overrides this to point at the colocated Postgres service, so this
# value is only consulted when running `kosatka-mesh master run` outside
# Docker. The master process auto-creates the parent directory on
# startup so the default below works without `mkdir data` first.
KOSATKA_DATABASE_URL=sqlite+aiosqlite:///./data/kosatka.db

# Shared secret used to sign outgoing webhook payloads (see
# `KosatkaWebhookHandler`). Anyone consuming the master's webhooks
# should validate the signature with this value.
KOSATKA_WEBHOOK_SECRET=change-me

# How often the scheduler reconciles node health and subscription expiry,
# in seconds.
KOSATKA_SYNC_INTERVAL=60
KOSATKA_EXPIRATION_CHECK_INTERVAL=300
