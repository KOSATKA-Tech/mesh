# KOSATKA Master Configuration
KOSATKA_API_KEY=your_secure_key_here
KOSATKA_DOMAIN=master.yourdomain.com
KOSATKA_AUTO_HTTPS=true
KOSATKA_BOT_USERNAME=YourBotName
KOSATKA_DATABASE_URL=sqlite+aiosqlite:////app/data/kosatka.db

# SMTP Settings for Trial Emails
KOSATKA_SMTP_HOST=smtp.gmail.com
KOSATKA_SMTP_PORT=587
KOSATKA_SMTP_USER=admin@yourdomain.com
KOSATKA_SMTP_PASSWORD=your_app_password

# Allowed Origins for Landing Page CORS (comma separated)
KOSATKA_ALLOWED_ORIGINS=https://kosatka.tech,https://your-landing.pages.dev
