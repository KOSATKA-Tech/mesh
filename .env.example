# ───────────────────────────────────────────────────────────────────────────
# KOSATKA Mesh — example environment file
# Copy to `.env` before running `docker compose up` or `kosatka-mesh master run`.
# Every variable is read by `kosatka_master/config.py` and prefixed with
# `KOSATKA_` at runtime.
# ───────────────────────────────────────────────────────────────────────────

# Admin API key. Required by every `/api/v1/*` endpoint (header
# `X-Kosatka-Key`). Pick a random, long string.
KOSATKA_API_KEY=change-me-to-a-long-random-string

# SQLAlchemy async URL. Use SQLite for local dev, Postgres for prod.
# When deploying via ``docker compose -f docker-compose.master.yml`` this
# variable is overridden by the compose file to target the colocated
# Postgres container (postgresql+asyncpg://kosatka:kosatka@postgres:5432/kosatka),
# so the value here only matters for ``kosatka-mesh master run`` outside
# Docker. The master process auto-creates the parent directory for the
# sqlite file on startup.
KOSATKA_DATABASE_URL=sqlite+aiosqlite:///./data/kosatka.db

# Shared secret used to sign outgoing webhook payloads (see KosatkaWebhookHandler).
KOSATKA_WEBHOOK_SECRET=change-me

# How often the scheduler reconciles node health and subscription expiry.
KOSATKA_SYNC_INTERVAL=60
KOSATKA_EXPIRATION_CHECK_INTERVAL=300

# ───────────────────────────────────────────────────────────────────────────
# Agent (docker-compose.agent.yml) — set on the AGENT host.
# ───────────────────────────────────────────────────────────────────────────

# Shared secret the master uses when calling this agent's API. Pick a
# random string per agent; the master stores its copy as ``api_key`` on
# the matching node row when ``kosatka-mesh nodes add`` is run.
AGENT_API_KEY=change-me-per-agent

# Which VPN backend the agent should expose: wireguard | awg | marzban | xray.
AGENT_PROVIDER_TYPE=wireguard

# Public URL of the master, used by the install / registration scripts.
KOSATKA_MASTER_URL=https://your-master-domain.example.com

# Marzban-specific overrides (only when AGENT_PROVIDER_TYPE=marzban).
# AGENT_MARZBAN_URL=https://marzban.example.com
# AGENT_MARZBAN_USERNAME=admin
# AGENT_MARZBAN_PASSWORD=change-me
